# ZeptoMail (in-region: api.zeptomail.in) — used by /api/contact to email
# the Contact Us form submissions. Domain notutor.ai is verified in ZeptoMail.
#
# Get the raw token from ZeptoMail console -> Mail Agents -> API. Keep the
# "Zoho-enczapikey " prefix; the route forwards the whole string as the
# Authorization header verbatim.

ZEPTOMAIL_TOKEN=Zoho-enczapikey <YOUR_TOKEN_HERE>
ZEPTOMAIL_FROM_ADDRESS=noreply@notutor.ai
ZEPTOMAIL_FROM_NAME=Weisscoat
CONTACT_TO_ADDRESS=guna@weisscoat.com
CONTACT_TO_NAME=Guna
# Comma-separated list of CC recipients. Each entry is "email" or "email|Name".
# e.g. CONTACT_CC_ADDRESSES=kasturi.phanindra@weisscoat.com|Kasturi Phanindra,someone-else@example.com
CONTACT_CC_ADDRESSES=kasturi.phanindra@weisscoat.com|Kasturi Phanindra
